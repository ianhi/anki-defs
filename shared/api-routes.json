      "note": "Session management not yet implemented on Android"
    },
    {
      "method": "POST",
      "path": "/api/session/pending",
      "note": "Session management not yet implemented on Android"
    },
    {
      "method": "DELETE",
      "path": "/api/session/pending/:id",
      "note": "Session management not yet implemented on Android"
    },
    {
      "method": "POST",
      "path": "/api/session/pending/:id/promote",
      "note": "Session management not yet implemented on Android"
    },
    {
      "method": "POST",
      "path": "/api/session/clear",
      "note": "Session management not yet implemented on Android"
    },
    {
      "method": "GET",
      "path": "/api/tts/check",
      "note": "Cloud TTS availability check — not applicable on Android"
    }
