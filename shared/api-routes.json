    { "method": "POST", "path": "/api/anki/notes" },
    { "method": "GET", "path": "/api/anki/notes/:id" },
    { "method": "DELETE", "path": "/api/anki/notes/:id" },
    { "method": "GET", "path": "/api/anki/status" },
    { "method": "POST", "path": "/api/chat/stream" },
    { "method": "POST", "path": "/api/chat/relemmatize" },
    { "method": "POST", "path": "/api/chat/distractors" },
    { "method": "GET", "path": "/api/settings" },
    { "method": "PUT", "path": "/api/settings" }
